#include <WiFi.h>
#include <WebServer.h>


const char* ssid ="vivo";
const char* pass = "Debasish";


int IN1 = 27;
int IN2 = 26;
int ENA = 25;

int speedLevel = 0;
// Used to prevent constant motor updates 
int lastSpeedLevel = -100; 

WebServer server(80);

void handleRoot() {
  String html = R"rawliteral(
  <html>
  <head><meta name="viewport" content="width=device-width, initial-scale=1"></head>
  <body style="text-align:center; font-family:sans-serif; background-color:#f4f4f4;">
    <h2>ESP32 Motor Control</h2>
    <p>Backward <-- Stop --> Forward</p>
    <input type="range" min="-10" max="10" value="0" 
           style="width:80%; height:50px;" oninput="send(this.value)">
    <h1 id="val" style="font-size:48px;">0</h1>
    <script>
      function send(v){
        document.getElementById("val").innerHTML = v;
        fetch("/move?val=" + v);
      }
    </script>
  </body>
  </html>
  )rawliteral";
  server.send(200, "text/html", html);
}

void motorControl() {
  //  Stop Condition
  if (speedLevel == 0) {
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, LOW);
    analogWrite(ENA, 0);
    Serial.println("Motor Stopped");
    return;
  }

  //  for Direction Control
  if (speedLevel > 0) {         // Forward
    digitalWrite(IN1, HIGH);
    digitalWrite(IN2, LOW);
    Serial.print("Forward Speed: ");
  } 
  else if (speedLevel < 0) {    // Backword
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, HIGH);
    Serial.print("Backward Speed: ");
  }

  // Speed Control 
  int spd = abs(speedLevel); 
  int pwmValue = map(spd, 1, 10, 80, 255); 
  
  analogWrite(ENA, pwmValue); 
  Serial.println(pwmValue);
}

void setup() {
  Serial.begin(115200);
  
  
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(ENA, OUTPUT);

  
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);

  
  WiFi.setSleep(false); 
  WiFi.begin(ssid, pass);

  Serial.print("Connecting to WiFi");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nConnected!");
  Serial.print("IP Address: "); 
  Serial.println(WiFi.localIP());

  
  server.on("/", handleRoot); 
  server.on("/move", []() {
    if (server.hasArg("val")) {
      speedLevel = server.arg("val").toInt();
    }
    server.send(200, "text/plain", "OK");
  });

  server.begin();
}

void loop() {
  server.handleClient();

  
  if (speedLevel != lastSpeedLevel) {
    motorControl();
    lastSpeedLevel = speedLevel;
  }
}
